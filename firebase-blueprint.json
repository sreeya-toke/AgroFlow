{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "description": "User email address" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "URL to user profile picture" },
        "settings": {
          "type": "object",
          "properties": {
            "notifyLowMoisture": { "type": "boolean" },
            "notifyRain": { "type": "boolean" },
            "drynessThreshold": { "type": "number" },
            "language": { "type": "string", "enum": ["en", "hi", "es"] }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "SensorData": {
      "title": "SensorData",
      "description": "Real-time sensor readings for a user's farm",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "soilMoisture": { "type": "number" },
        "temperature": { "type": "number" },
        "humidity": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "soilMoisture", "temperature", "humidity", "lastUpdated"]
    },
    "ImageGeneration": {
      "title": "ImageGeneration",
      "description": "History of images generated by the user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "prompt": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "prompt", "imageUrl", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "/sensor_readings/{readingId}": {
      "schema": "SensorData",
      "description": "Stream of sensor data points"
    },
    "/image_history/{generationId}": {
      "schema": "ImageGeneration",
      "description": "Log of generated images"
    }
  }
}
